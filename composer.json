{
  "name": "noteforge/noteforge",
  "description": "NoteForge - minimal Notion-lite clone on Phalcon using MarkForge",
  "type": "project",
  "license": "MIT",
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/Smiley-Alyx/markforge"
    }
  ],
  "require": {
    "php": "^8.5",
    "markforge/markforge": "^0.1",
    "robmorgan/phinx": "^0.16",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "NoteForge\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "NoteForge\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "migrate": "phinx migrate -c phinx.php",
    "migrate:rollback": "phinx rollback -c phinx.php"
  }
}
